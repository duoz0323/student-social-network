// =============================================================================
// STUDENT SOCIAL NETWORK - DATABASE MODEL (DBML)
// Đồng bộ với file student_social_network_db_cap_nhat.sql sau khi cập nhật luồng đăng ký.
// Phạm vi: MVP mạng xã hội tinh gọn dành cho sinh viên.
// Lưu ý:
// - Người dùng đăng ký bằng một trong hai phương thức: email hoặc số điện thoại.
// - Email và số điện thoại đều có thể NULL, nhưng mỗi tài khoản phải có ít nhất một phương thức.
// - Database cho phép bổ sung phương thức còn thiếu sau khi tài khoản đã được tạo.
// - MVP chưa xác minh email/SMS OTP; các cột thời điểm xác minh được chuẩn bị cho hướng phát triển.
// - Không sử dụng username.
// - Sau đăng ký, hệ thống tạo user_profiles rỗng trong cùng transaction với users.
// - Tên hiển thị bắt buộc để hoàn tất hồ sơ; avatar, ngày sinh và bio có thể bỏ qua.
// - profile_completed_at xác định người dùng đã hoàn tất onboarding.
// - Ngày sinh được lưu trong user_profiles.date_of_birth.
// - Trigger, CHECK phức tạp, VIEW và FULLTEXT INDEX được mô tả bằng Note vì DBML
//   chủ yếu dùng để biểu diễn bảng, khóa, index và quan hệ.
// =============================================================================

Project student_social_network {
  database_type: "MySQL"
  Note: "Cơ sở dữ liệu MVP cho hệ thống mạng xã hội tinh gọn dành cho sinh viên."
}

// =============================================================================
// ENUM
// =============================================================================

Enum user_role {
  USER
  ADMIN
}

Enum user_status {
  ACTIVE
  BLOCKED
}

Enum password_delivery_channel {
  EMAIL
  SMS
}

Enum post_status {
  PUBLISHED
  HIDDEN
  DELETED
}

Enum post_media_mime_type {
  "image/jpeg"
  "image/png"
  "image/webp"
}

Enum comment_status {
  PUBLISHED
  DELETED
}

Enum report_reason {
  SPAM
  HARASSMENT
  HARMFUL_CONTENT
  VIOLENCE
  MISINFORMATION
  INAPPROPRIATE
  OTHER
}

Enum report_status {
  PENDING
  RESOLVED
  REJECTED
}

Enum admin_action_type {
  BLOCK_USER
  UNBLOCK_USER
  HIDE_POST
  RESTORE_POST
  RESOLVE_REPORT
  REJECT_REPORT
}

Enum admin_target_type {
  USER
  POST
  REPORT
}

// =============================================================================
// 1. TÀI KHOẢN VÀ HỒ SƠ
// =============================================================================

Table users {
  id bigint [pk, increment, not null, note: "Khóa chính."]
  email varchar(255) [unique, note: "Có thể NULL khi đăng ký bằng số điện thoại; Backend chuẩn hóa về chữ thường trước khi lưu."]
  phone_number varchar(20) [unique, note: "Có thể NULL khi đăng ký bằng email; Backend chuẩn hóa về một định dạng thống nhất trước khi lưu."]
  email_verified_at datetime(6) [note: "Thời điểm xác minh email; NULL khi chưa xác minh hoặc tài khoản chưa có email."]
  phone_verified_at datetime(6) [note: "Thời điểm xác minh số điện thoại; NULL khi chưa xác minh hoặc tài khoản chưa có số điện thoại."]
  password_hash varchar(255) [not null, note: "Mật khẩu đã băm bằng BCrypt hoặc Argon2."]
  role user_role [not null, default: 'USER']
  status user_status [not null, default: 'ACTIVE']
  blocked_at datetime(6) [note: "Thời điểm tài khoản bị khóa."]
  blocked_reason varchar(500) [note: "Lý do khóa tài khoản."]
  created_at datetime(6) [not null, default: `CURRENT_TIMESTAMP(6)`]
  updated_at datetime(6) [not null, default: `CURRENT_TIMESTAMP(6)`, note: "MySQL tự cập nhật bằng ON UPDATE CURRENT_TIMESTAMP(6)."]

  Indexes {
    (status, created_at, id) [name: "idx_users_status_created_at"]
  }

  Note: "CHECK trong file SQL: email/phone_number nếu có thì không được rỗng; phải tồn tại ít nhất một phương thức định danh; không được có thời điểm xác minh nếu phương thức tương ứng chưa tồn tại; status ACTIVE yêu cầu blocked_at NULL, status BLOCKED yêu cầu blocked_at khác NULL. Request đăng ký chỉ nhận đúng một phương thức, nhưng database cho phép có cả hai sau khi người dùng bổ sung thông tin bảo mật."
}

Table user_profiles {
  user_id bigint [pk, not null, note: "Khóa chính đồng thời là khóa ngoại tới users.id."]
  display_name varchar(100) [note: "NULL trong thời gian onboarding; bắt buộc để hoàn tất hồ sơ."]
  avatar_url varchar(1000) [note: "Tùy chọn; NULL khi người dùng bỏ qua ảnh đại diện."]
  avatar_public_id varchar(255)
  bio varchar(500) [note: "Tùy chọn; người dùng được phép bỏ qua."]
  date_of_birth date [note: "Tùy chọn; Backend từ chối ngày nằm trong tương lai nếu có dữ liệu."]
  profile_completed_at datetime(6) [note: "NULL khi chưa hoàn tất; được cập nhật sau khi display_name hợp lệ và người dùng xác nhận hoàn tất."]
  created_at datetime(6) [not null, default: `CURRENT_TIMESTAMP(6)`]
  updated_at datetime(6) [not null, default: `CURRENT_TIMESTAMP(6)`, note: "MySQL tự cập nhật bằng ON UPDATE CURRENT_TIMESTAMP(6)."]

  Note: "Một hồ sơ rỗng được tạo cùng transaction với users. CHECK trong file SQL: display_name nếu có không được rỗng; profile_completed_at chỉ có giá trị khi display_name khác NULL. Có FULLTEXT INDEX trên display_name."
}

Table refresh_tokens {
  id bigint [pk, increment, not null]
  user_id bigint [not null]
  token_hash char(64) [not null, unique, note: "Chỉ lưu SHA-256 hash của Refresh Token."]
  device_id varchar(100)
  device_info varchar(500)
  ip_address varchar(45)
  expires_at datetime(6) [not null]
  revoked_at datetime(6)
  created_at datetime(6) [not null, default: `CURRENT_TIMESTAMP(6)`]

  Indexes {
    (user_id, revoked_at, expires_at, id) [name: "idx_refresh_tokens_user_expiry"]
  }

  Note: "CHECK: expires_at > created_at; revoked_at phải NULL hoặc >= created_at."
}

Table password_reset_tokens {
  id bigint [pk, increment, not null]
  user_id bigint [not null]
  delivery_channel password_delivery_channel [not null]
  token_hash char(64) [not null, unique]
  expires_at datetime(6) [not null]
  used_at datetime(6)
  created_at datetime(6) [not null, default: `CURRENT_TIMESTAMP(6)`]

  Indexes {
    (user_id, used_at, expires_at, id) [name: "idx_password_reset_tokens_user_state"]
  }

  Note: "CHECK: expires_at > created_at; used_at phải NULL hoặc >= created_at."
}

// =============================================================================
// 2. QUAN HỆ THEO DÕI
// =============================================================================

Table follows {
  follower_id bigint [not null, note: "Người thực hiện Follow."]
  following_id bigint [not null, note: "Người được Follow."]
  created_at datetime(6) [not null, default: `CURRENT_TIMESTAMP(6)`]

  Indexes {
    (follower_id, following_id) [pk, name: "pk_follows"]
    (following_id, created_at, follower_id) [name: "idx_follows_following_created_at"]
    (follower_id, created_at, following_id) [name: "idx_follows_follower_created_at"]
  }

  Note: "CHECK: follower_id phải khác following_id."
}

// =============================================================================
// 3. BÀI VIẾT, MEDIA VÀ HASHTAG
// =============================================================================

Table posts {
  id bigint [pk, increment, not null]
  author_id bigint [not null]
  content varchar(500)
  status post_status [not null, default: 'PUBLISHED']
  is_edited boolean [not null, default: false]
  like_count int [not null, default: 0, note: "Bộ đếm dư thừa có kiểm soát để tối ưu Feed."]
  comment_count int [not null, default: 0, note: "Bộ đếm dư thừa có kiểm soát để tối ưu Feed."]
  published_at datetime(6) [not null, default: `CURRENT_TIMESTAMP(6)`]
  hidden_by bigint [note: "Admin thực hiện ẩn bài."]
  hidden_at datetime(6)
  hidden_reason varchar(500)
  deleted_at datetime(6)
  created_at datetime(6) [not null, default: `CURRENT_TIMESTAMP(6)`]
  updated_at datetime(6) [not null, default: `CURRENT_TIMESTAMP(6)`, note: "MySQL tự cập nhật bằng ON UPDATE CURRENT_TIMESTAMP(6)."]

  Indexes {
    (author_id, status, published_at, id) [name: "idx_posts_author_status_published"]
    (status, published_at, id) [name: "idx_posts_status_published"]
    (status, like_count, comment_count, published_at, id) [name: "idx_posts_status_engagement"]
  }

  Note: "Có FULLTEXT INDEX trên content. CHECK trạng thái HIDDEN/DELETED được định nghĩa trong file SQL."
}

Table post_media {
  id bigint [pk, increment, not null]
  post_id bigint [not null]
  media_url varchar(1000) [not null]
  storage_public_id varchar(255) [not null, unique]
  mime_type post_media_mime_type [not null]
  file_size_bytes bigint [not null]
  width_px int
  height_px int
  display_order tinyint [not null]
  created_at datetime(6) [not null, default: `CURRENT_TIMESTAMP(6)`]

  Indexes {
    (post_id, display_order) [unique, name: "uq_post_media_post_order"]
  }

  Note: "CHECK: display_order từ 0 đến 3; file_size_bytes > 0."
}

Table hashtags {
  id bigint [pk, increment, not null]
  normalized_name varchar(100) [not null, unique, note: "Tên hashtag dạng chữ thường, không có ký tự #."]
  display_name varchar(100) [not null]
  post_count int [not null, default: 0]
  created_at datetime(6) [not null, default: `CURRENT_TIMESTAMP(6)`]
  updated_at datetime(6) [not null, default: `CURRENT_TIMESTAMP(6)`, note: "MySQL tự cập nhật bằng ON UPDATE CURRENT_TIMESTAMP(6)."]

  Indexes {
    (post_count, id) [name: "idx_hashtags_post_count"]
  }

  Note: "CHECK: normalized_name không được rỗng."
}

Table post_hashtags {
  post_id bigint [not null]
  hashtag_id bigint [not null]
  created_at datetime(6) [not null, default: `CURRENT_TIMESTAMP(6)`]

  Indexes {
    (post_id, hashtag_id) [pk, name: "pk_post_hashtags"]
    (hashtag_id, post_id) [name: "idx_post_hashtags_hashtag_post"]
  }
}

// =============================================================================
// 4. TƯƠNG TÁC
// =============================================================================

Table post_likes {
  user_id bigint [not null]
  post_id bigint [not null]
  created_at datetime(6) [not null, default: `CURRENT_TIMESTAMP(6)`]

  Indexes {
    (user_id, post_id) [pk, name: "pk_post_likes"]
    (post_id, created_at, user_id) [name: "idx_post_likes_post_created"]
  }
}

Table comments {
  id bigint [pk, increment, not null]
  post_id bigint [not null]
  user_id bigint [not null]
  parent_comment_id bigint [note: "NULL nếu là bình luận gốc; MVP chỉ hỗ trợ trả lời tối đa một cấp."]
  content varchar(1000) [not null]
  status comment_status [not null, default: 'PUBLISHED']
  deleted_at datetime(6)
  created_at datetime(6) [not null, default: `CURRENT_TIMESTAMP(6)`]
  updated_at datetime(6) [not null, default: `CURRENT_TIMESTAMP(6)`, note: "MySQL tự cập nhật bằng ON UPDATE CURRENT_TIMESTAMP(6)."]

  Indexes {
    (post_id, parent_comment_id, status, created_at, id) [name: "idx_comments_post_parent_created"]
    (user_id, status, created_at, id) [name: "idx_comments_user_created"]
  }

  Note: "CHECK: content không rỗng; trạng thái DELETED phải có deleted_at."
}

Table saved_posts {
  user_id bigint [not null]
  post_id bigint [not null]
  created_at datetime(6) [not null, default: `CURRENT_TIMESTAMP(6)`]

  Indexes {
    (user_id, post_id) [pk, name: "pk_saved_posts"]
    (user_id, created_at, post_id) [name: "idx_saved_posts_user_created"]
    (post_id, created_at, user_id) [name: "idx_saved_posts_post_created"]
  }
}

// =============================================================================
// 5. BÁO CÁO VÀ QUẢN TRỊ
// =============================================================================

Table reports {
  id bigint [pk, increment, not null]
  reporter_id bigint [not null]
  post_id bigint [not null]
  reason report_reason [not null]
  description varchar(1000)
  status report_status [not null, default: 'PENDING']
  resolved_by bigint [note: "Admin xử lý báo cáo."]
  resolved_at datetime(6)
  resolution_note varchar(1000)
  post_content_snapshot varchar(500)
  post_media_snapshot json
  pending_report_key varchar(100) [unique, note: "Cột sinh tự động trong MySQL, chỉ có giá trị khi status=PENDING."]
  created_at datetime(6) [not null, default: `CURRENT_TIMESTAMP(6)`]
  updated_at datetime(6) [not null, default: `CURRENT_TIMESTAMP(6)`, note: "MySQL tự cập nhật bằng ON UPDATE CURRENT_TIMESTAMP(6)."]

  Indexes {
    (status, created_at, id) [name: "idx_reports_status_created"]
    (post_id, status, created_at, id) [name: "idx_reports_post_status"]
    (reporter_id, created_at, id) [name: "idx_reports_reporter_created"]
  }

  Note: "CHECK: báo cáo đã xử lý phải có resolved_by và resolved_at."
}

Table account_status_histories {
  id bigint [pk, increment, not null]
  user_id bigint [not null]
  old_status user_status [not null]
  new_status user_status [not null]
  changed_by bigint [not null, note: "Admin thực hiện thay đổi."]
  reason varchar(500) [not null]
  created_at datetime(6) [not null, default: `CURRENT_TIMESTAMP(6)`]

  Indexes {
    (user_id, created_at, id) [name: "idx_account_status_histories_user_created"]
  }

  Note: "CHECK: old_status phải khác new_status. Trigger kiểm tra changed_by có vai trò ADMIN."
}

Table admin_actions {
  id bigint [pk, increment, not null]
  admin_id bigint [not null]
  action_type admin_action_type [not null]
  target_type admin_target_type [not null]
  target_id bigint [not null, note: "Khóa đa hình; được Service kiểm tra theo target_type."]
  note varchar(1000)
  old_data json
  new_data json
  created_at datetime(6) [not null, default: `CURRENT_TIMESTAMP(6)`]

  Indexes {
    (target_type, target_id, created_at, id) [name: "idx_admin_actions_target_created"]
    (admin_id, created_at, id) [name: "idx_admin_actions_admin_created"]
  }

  Note: "target_id không dùng khóa ngoại trực tiếp vì tham chiếu nhiều loại đối tượng."
}

// =============================================================================
// QUAN HỆ
// =============================================================================

Ref: user_profiles.user_id > users.id [delete: cascade, update: restrict]

Ref: refresh_tokens.user_id > users.id [delete: cascade, update: restrict]
Ref: password_reset_tokens.user_id > users.id [delete: cascade, update: restrict]

Ref: follows.follower_id > users.id [delete: cascade, update: restrict]
Ref: follows.following_id > users.id [delete: cascade, update: restrict]

Ref: posts.author_id > users.id [delete: restrict, update: restrict]
Ref: posts.hidden_by > users.id [delete: restrict, update: restrict]

Ref: post_media.post_id > posts.id [delete: cascade, update: restrict]

Ref: post_hashtags.post_id > posts.id [delete: cascade, update: restrict]
Ref: post_hashtags.hashtag_id > hashtags.id [delete: restrict, update: restrict]

Ref: post_likes.user_id > users.id [delete: cascade, update: restrict]
Ref: post_likes.post_id > posts.id [delete: cascade, update: restrict]

Ref: comments.post_id > posts.id [delete: cascade, update: restrict]
Ref: comments.user_id > users.id [delete: restrict, update: restrict]
Ref: comments.parent_comment_id > comments.id [delete: cascade, update: restrict]

Ref: saved_posts.user_id > users.id [delete: cascade, update: restrict]
Ref: saved_posts.post_id > posts.id [delete: cascade, update: restrict]

Ref: reports.reporter_id > users.id [delete: restrict, update: restrict]
Ref: reports.post_id > posts.id [delete: restrict, update: restrict]
Ref: reports.resolved_by > users.id [delete: restrict, update: restrict]

Ref: account_status_histories.user_id > users.id [delete: restrict, update: restrict]
Ref: account_status_histories.changed_by > users.id [delete: restrict, update: restrict]

Ref: admin_actions.admin_id > users.id [delete: restrict, update: restrict]
